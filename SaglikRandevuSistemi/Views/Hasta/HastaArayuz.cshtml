@section Arayuz
{
    <link href="~/css/Arayuz.css" rel="stylesheet" type="text/css" />
}

@await Html.PartialAsync("~/Views/PartialViews/_HastaArayuzHeader.cshtml")

<div class="container" style="height: 566.5px;">
    <div class="main-section">
        <div class="left-section">
            <a href="@Url.Action("AramaFiltresi","Hasta")" class="button" style="height: 200px;"><p> Randevu Al </p><br><span style="font-size: 14px;">Kişisel filtreleme yaparak dilediğiniz randevuyu alabilirsiniz.</span></a>
        </div>
        <div class="tabs">
            <div class="tabs-header">
                <div class="tab active">Randevularım</div>
                <div class="tab">Geçmiş Randevularım</div>
            </div>
            <div class="tab-content">

                <div class="data-box">Randevu 1 - 15:30</div> <!-- veri var ise verinin kendisi for/while ile div olusturularak yazilacaktir.-->

                <div class="data-box">Randevu 1 - 15:30</div>
                <div class="data-box">Randevu 2 - 16:00</div>
                <div class="data-box">Randevu 3 - 16:30</div>
                <div class="data-box">Randevu 1 - 15:30</div>
                <div class="data-box">Randevu 2 - 16:00</div>
                <div class="data-box">Randevu 3 - 16:30</div>

                <div class="card">Aktif Randevunuz Yok</div> <!-- Eger veri yoksa bu yazilacaktir -->
            </div>
            <div class="tab-content">
                <div class="data-box">Randevu 1 - 15:30</div>
                <div class="data-box">Randevu 2 - 16:00</div>
                <div class="data-box">Randevu 3 - 16:30</div>

                <div class="card">Aktif Randevunuz Yok</div>
            </div>
        </div>
    </div>
</div>
<script src="~/js/Arayuz.js"></script>
<script>
        window.history.pushState(null, "", window.location.href); // Geçmişi değiştir
    window.onpopstate = function () {
        window.history.pushState(null, "", window.location.href); // Geri tuşu engellenir, mevcut sayfada kalır
    };
</script>